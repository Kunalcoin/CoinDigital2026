# Copy to .env in this folder (django-docker-compose) to run the site locally.
# Option A: SQLite (no MySQL) – easiest
SERVER=LOCAL_SQLITE
SECRET_KEY=your-secret-key-here

# Option B: Local MySQL – use your local MySQL credentials
# SERVER=LOCAL
# LOCAL_DB_HOST=127.0.0.1
# LOCAL_DB_USER=root
# LOCAL_DB_PASSWORD=yourpassword
# SECRET_KEY=your-secret-key-here

# Optional: AWS/S3 (for uploads and DDEX)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# Optional: DDEX delivery (leave empty to skip)
# DELIVERY_STORES=audiomack,gaana,tiktok
