# Node (if using npm/yarn for frontend)
node_modules/

# Backup folders and files (do not commit)
*-backup-*/
**/*-backup-*/
*.backup
*.backup_*

# Database backup artifacts (do not commit)
db_backups/
backup_db/
*.sql.gz
*.dump
*.dmp
